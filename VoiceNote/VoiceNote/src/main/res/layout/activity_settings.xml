<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/action_settings"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp" />

        <!-- PHẦN OBSIDIAN -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="OBSIDIAN SYNC"
            android:textColor="#4CAF50"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switch_auto_export"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/auto_export_title"
            android:textColor="#FFFFFF"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/text_vault_path"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Path not set"
            android:textColor="#888888"
            android:textSize="14sp"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btn_select_vault"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/select_vault"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:textColor="#4CAF50"
            app:strokeColor="#4CAF50"
            android:layout_marginBottom="24dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#333333"
            android:layout_marginBottom="24dp" />

        <!-- PHẦN GIỌNG NÓI -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/voice_recognition_header"
            android:textColor="#2196F3"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/default_lang_label"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="8dp" />

        <RadioGroup
            android:id="@+id/rg_language"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">
            <RadioButton
                android:id="@+id/rb_vi"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tiếng Việt"
                android:textColor="#FFFFFF"
                android:buttonTint="#2196F3"
                android:layout_marginEnd="16dp" />
            <RadioButton
                android:id="@+id/rb_en"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="English"
                android:textColor="#FFFFFF"
                android:buttonTint="#2196F3" />
        </RadioGroup>

        <Button
            android:id="@+id/btn_apply_language"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ÁP DỤNG / APPLY"
            android:backgroundTint="#2196F3"
            android:layout_marginBottom="24dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/custom_commands_label"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:id="@+id/container_commands"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <Button
            android:id="@+id/btn_add_command"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/add_command"
            android:layout_marginTop="8dp"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:textColor="#2196F3" />

    </LinearLayout>
</ScrollView>
